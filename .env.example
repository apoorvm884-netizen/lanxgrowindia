# ==============================================================
# LANXGROW COS — Environment Variables
# ==============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ==============================================================

# --- Supabase (required) ---
# Find these in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Supabase Service Role Key (server-side ONLY) ---
# NEVER expose this to the frontend.
# Used only in Edge Functions and backend scripts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Google OAuth (configured in Supabase Dashboard) ---
# No frontend env vars needed.
# Set up at: Supabase Dashboard → Authentication → Providers → Google
# Google Cloud Console: APIs & Services → Credentials → OAuth 2.0 Client IDs
# Add authorized redirect URI: https://your-project.supabase.co/auth/v1/callback

# --- Demo Mode (optional, for development only) ---
# Set to 'true' to enable demo mode with hardcoded credentials
# Defaults to false in production
# VITE_DEMO_MODE=false

# --- Development Access Mode (optional, for development only) ---
# Set to 'true' to show "Enter Development Mode" button on the login page
# Allows auto-login as development super admin for testing
# Defaults to false in production
# VITE_DEV_ACCESS=false
